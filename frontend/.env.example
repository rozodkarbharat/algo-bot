# TradingBot Dashboard — Frontend Environment Variables
# Copy to .env and adjust for your deployment

# Backend API base URL (empty = use Vite proxy in dev, absolute URL in prod)
VITE_API_BASE_URL=

# WebSocket base URL (empty = derive from window.location in dev)
# In production set to: wss://yourdomain.com
VITE_WS_BASE_URL=
