# ─────────────────────────────────────────────────────────────────────────────
# TradingBot — Environment Configuration Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Application
APP_NAME=TradingBot
APP_ENV=development          # development | staging | production
DEBUG=true

# MongoDB
MONGO_URI=mongodb://localhost:27017
DATABASE_NAME=trading_bot

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# AngelOne SmartAPI credentials
ANGELONE_API_KEY=your_api_key_here
ANGELONE_CLIENT_ID=your_client_id_here
ANGELONE_PASSWORD=your_password_here
ANGELONE_TOTP_SECRET=your_totp_secret_here

# CORS — comma-separated list of allowed frontend origins
# CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Data ingestion
ANGELONE_BASE_URL=https://apiconnect.angelone.in
INGESTION_API_DELAY_SECONDS=0.5
ANGELONE_API_RATE_PER_SECOND=2.5
ANGELONE_API_RATE_PER_MINUTE=150
INGESTION_CONCURRENCY=2
INGESTION_DEFAULT_START_DATE=2020-01-01

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# Scheduler
SCHEDULER_TIMEZONE=Asia/Kolkata

# ORHV strategy — history guard (auto-backfill before Phase 2 validation)
ORHV_AUTO_BACKFILL_ENABLED=true     # sync + detect missing history before validating
ORHV_HISTORY_LOOKBACK_DAYS=365      # calendar-day window the guard backfills (first run is heavy)

# Live Signal Engine
LIVE_MAX_ORB_RANGE_PCT=1.0          # skip stocks whose first-candle range > this %
LIVE_MAX_ENTRY_TIME_IST=11:30       # latest candle open time allowed for live entry
LIVE_RESPECT_MARKET_HOURS=true      # drop ticks outside NSE regular session hours

# Live Execution Engine (REAL money — keep LIVE_EXEC_ENABLED=false until cutover)
LIVE_EXEC_ENABLED=false              # master switch for placing REAL broker orders
LIVE_EXEC_CAPITAL_PER_TRADE=50000    # capital deployed per real-money trade (INR)
LIVE_EXEC_TOTAL_CAPITAL=500000       # total live capital pool (INR) — basis for risk %
LIVE_EXEC_MAX_TRADES_PER_DAY=5       # max live entries per trading day
LIVE_EXEC_MAX_OPEN_POSITIONS=3       # max concurrent open live positions
LIVE_EXEC_MAX_POSITION_PCT=15.0      # max single-trade exposure as % of total capital
LIVE_EXEC_MAX_CAPITAL_EXPOSURE_PCT=50.0   # aggregate-exposure ceiling as % of total
LIVE_EXEC_MAX_DAILY_LOSS_PCT=1.5     # daily loss limit (% total) before auto-halt
LIVE_EXEC_MAX_DRAWDOWN_PCT=5.0       # max drawdown (% total) before auto-halt
LIVE_EXEC_EOD_EXIT_TIME_IST=15:15    # forced square-off time (IST)
LIVE_EXEC_DEFAULT_ORDER_TYPE=MARKET  # MARKET | LIMIT
LIVE_EXEC_DEFAULT_PRODUCT=INTRADAY   # INTRADAY (MIS) | DELIVERY (CNC)
LIVE_EXEC_MAX_DATA_STALENESS_SECONDS=120.0
LIVE_EXEC_ORDER_MAX_RETRIES=2
LIVE_EXEC_ORDER_RETRY_BACKOFF_SECONDS=1.0
LIVE_EXEC_ORDER_POLL_INTERVAL_SECONDS=5.0
LIVE_EXEC_DEFAULT_EXCHANGE=NSE
LIVE_EXEC_REQUIRE_MARKET_OPEN=true   # reject live orders outside NSE session hours

# ── Notification category toggles ────────────────────────────────────────────
NOTIFY_ENABLED=true                  # master switch — false disables all external notifications
NOTIFY_TRADE_ALERTS=true             # paper/live trade entry, exit, and stop-loss events
NOTIFY_SIGNAL_ALERTS=true            # new trading signal generated
NOTIFY_SYSTEM_ALERTS=true            # broker/WS disconnect, scheduler failures, errors
NOTIFY_DAILY_SUMMARY=true            # daily P&L summary at 15:45 IST
NOTIFY_THROTTLE_WINDOW_SECONDS=300   # seconds before the same event can fire again
NOTIFY_MAX_RETRIES=3                 # max send retries per notification
NOTIFY_RETRY_BACKOFF_SECONDS=2.0     # base back-off seconds (exponential)
